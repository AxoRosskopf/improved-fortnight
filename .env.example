# Google Sheets API Key (lectura pública - Sheets API v4)
# Crea una API Key en Google Cloud Console con la Sheets API habilitada.
GOOGLE_SHEETS_API_KEY=

# Google Service Account (escritura - pegar el JSON completo en una sola línea)
# El service account debe tener acceso de Editor en el spreadsheet.
GOOGLE_SERVICE_ACCOUNT_JSON=

# IDs de spreadsheets autorizados, separados por coma.
# Si se define, la API solo permitirá mutaciones sobre estos IDs.
ALLOWED_SPREADSHEET_IDS=

# Vercel Blob — token para almacenamiento de imágenes.
# Crear un Blob store en Vercel Dashboard → Storage → Create Database → Blob
# Luego: vercel env pull (agrega el token automáticamente a .env.local)
BLOB_READ_WRITE_TOKEN=

# --- Google Drive (legacy, ya no se usa para nuevas imágenes) ---
# ID de la carpeta en Drive donde se guardan las imágenes (REQUERIDO en producción).
# Los service accounts no tienen cuota de almacenamiento propia, por lo que las imágenes
# deben subirse a una carpeta creada por una cuenta Google real y compartida con el
# service account como Editor.
# Cómo obtener el ID: abrir la carpeta en Drive → copiar el ID de la URL
#   drive.google.com/drive/folders/<FOLDER_ID>
DRIVE_FOLDER_ID=

# Nombre de la carpeta (solo usado si DRIVE_FOLDER_ID no está definido).
# Se crea automáticamente si no existe. No funciona en producción por falta de cuota.
DRIVE_FOLDER_NAME=Inventario
